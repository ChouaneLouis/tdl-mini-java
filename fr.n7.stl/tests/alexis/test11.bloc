// [SUCCES] Test de masquage (shadowing): Variable locale 'x' masque l'attribut 'x', l'utilisation de 'this.x' permet d'y accéder.
class Shadow {
    public int x;
    public void setX(int x) {
        this.x = x;
    }
}
public class Principal {
    public static void main(String[] args) {
        Shadow s = new Shadow();
        s.setX(42);
        print s.x;
    }
}
