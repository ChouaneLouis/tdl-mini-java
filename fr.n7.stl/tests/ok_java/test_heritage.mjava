class Point {
    public int x;
    public int y;
    
    public Point(int _x, int _y) {
        this.x = _x;
        this.y = _y;
    }
}

class Point3D extends Point {
    public int z;
    
    public Point3D(int _x, int _y, int _z) {
        super(_x, _y);
        this.z = _z;
    }
}

public class Main {
    public static void main(String[] args) {
        Point p = new Point3D(10, 20, 30);

        print p.x;
        print p.y;

    }
}
