class Point {
    public int x;
    public int y;

    public Point() {
        this(0, 0); // Appel au constructeur avec 2 paramètres
    }

    public Point(int a) {
        this(a, a); // Appel au constructeur avec 2 paramètres
    }

    public Point(int x, int y) {
        this.x = x;
        this.y = y;
    }
}

public class Main {
    public static void main(String[] args) {
        Point p1 = new Point();
        Point p2 = new Point(5);
        Point p3 = new Point(10, 20);
    }
}
