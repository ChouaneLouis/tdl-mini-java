;(Counter.count + 1)
Constructor_Counter
LOAD (1) 0[SB]
LOADL 1
SUBR IAdd
LOADA 0[SB]
STOREI (1)
POP (0) 0
RETURN (0) 0
PUSH 1
LOADL 1
SUBR MAlloc
CALL (SB) Constructor_Counter
STORE (1) 0[SB]
PUSH 1
LOADL 1
SUBR MAlloc
CALL (SB) Constructor_Counter
STORE (1) 1[SB]
LOAD (1) 0[SB]
SUBR IOut
POP (0) 2
HALT
HALT

